<?xml version="1.0" encoding="UTF-8"?>
<!--
    routes.rou.xml — Fixed and Improved
    Changes from original:
      - Removed U-turn routes (original r13-r16: e.g. n0->center->n0)
      - Removed duplicate routes (original r17-r24 were exact duplicates of r0-r8)
      - Now 12 unique valid through-routes across the 4-way intersection
      - 500 vehicles spread evenly across all 12 routes
      - Departures spread over 0-99.8s (0.2s intervals = 5 vehicles/sec)
        giving a more realistic, sustained demand rather than a burst
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle type: standard urban car -->
    <vType id="car" accel="2.6" decel="4.5" length="5" maxSpeed="13.9" sigma="0.5"/>

    <!--
        12 valid through-routes. No U-turns. No duplicates.
        4 entry directions x 3 valid exits each = 12 routes.
    -->
    <route id="r_W_E" edges="n0_center center_n1"/>
    <route id="r_W_N" edges="n0_center center_n3"/>
    <route id="r_W_S" edges="n0_center center_n2"/>
    <route id="r_E_W" edges="n1_center center_n0"/>
    <route id="r_E_N" edges="n1_center center_n3"/>
    <route id="r_E_S" edges="n1_center center_n2"/>
    <route id="r_S_N" edges="n2_center center_n3"/>
    <route id="r_S_E" edges="n2_center center_n1"/>
    <route id="r_S_W" edges="n2_center center_n0"/>
    <route id="r_N_S" edges="n3_center center_n2"/>
    <route id="r_N_E" edges="n3_center center_n1"/>
    <route id="r_N_W" edges="n3_center center_n0"/>

